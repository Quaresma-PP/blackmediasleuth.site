# =============================================
# CONFIGURAÇÕES DO SERVIDOR
# =============================================
PORT=3001
NODE_ENV=development

# =============================================
# BANCO DE DADOS (PostgreSQL)
# Use Supabase grátis: https://supabase.com
# =============================================
DATABASE_URL=postgresql://usuario:senha@localhost:5432/dividas_db

# =============================================
# JWT - Autenticação
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================
JWT_SECRET=TROQUE_POR_UMA_CHAVE_FORTE_DE_64_CARACTERES
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=TROQUE_POR_OUTRA_CHAVE_FORTE_DIFERENTE
JWT_REFRESH_EXPIRES_IN=7d

# =============================================
# SEGURANÇA
# =============================================
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=CHAVE_HEX_DE_32_BYTES_64_CHARS

# =============================================
# CORS - URL do seu frontend
# =============================================
FRONTEND_URL=http://localhost:5500

# =============================================
# LGPD - Configurações de Privacidade
# =============================================
DATA_RETENTION_DAYS=365
AUDIT_LOG_ENABLED=true
